{
    "git.autofetch": true,
    "gitlens.advanced.messages": {
        "suppressShowKeyBindingsNotice": true
    },
    "explorer.confirmDelete": false,
    "extensions.ignoreRecommendations": true,
    "typescript.updateImportsOnFileMove.enabled": "always",
    "explorer.confirmDragAndDrop": false,
    "[typescript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[html]": {
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    "[markdown]": {
        "files.trimTrailingWhitespace": false,
        "editor.defaultFormatter": "yzhang.markdown-all-in-one"
    },
    "workbench.startupEditor": "newUntitledFile",
    "window.zoomLevel": 0,
    "terminal.integrated.shell.windows": "C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
    "auto-close-tag.activationOnLanguage": [
        "xml",
        "php",
        "blade",
        "ejs",
        "jinja",
        "plaintext",
        // "markdown",
        "vue",
        "liquid",
        "erb",
        "lang-cfml",
        "cfml",
        "HTML (EEx)",
        "HTML (Eex)",
        "plist"
    ],
    "javascript.updateImportsOnFileMove.enabled": "always",
    "editor.fontFamily": "'Cascadia Code', 'CaskaydiaCove Nerd Font', 'CaskaydiaCove NF'",
    "editor.letterSpacing": 1.2,
    "editor.fontLigatures": true,
    "disableLigatures.mode": "Cursor",
    "insertDateString.format": "YYYYMMDDhhmmss",
    "liveServer.settings.donotShowInfoMsg": true,
    "editor.tabSize": 2,
    "workbench.iconTheme": "material-icon-theme",
    "plantuml.server": "https://www.plantuml.com/plantuml",
    "editor.suggestSelection": "first",
    "files.exclude": {
        "**/.classpath": true,
        "**/.factorypath": true,
        "**/.history": true,
        "**/.project": true,
        "**/.settings": true
    },
    "vs-kubernetes": {
        "vs-kubernetes.helm-path.windows": "C:\\Users\\nlkhung\\.vs-kubernetes\\tools\\helm\\windows-amd64\\helm.exe",
        "vs-kubernetes.minikube-path.windows": "C:\\Users\\nlkhung\\.vs-kubernetes\\tools\\minikube\\windows-amd64\\minikube.exe",
        "vs-kubernetes.draft-path.windows": "C:\\Users\\nlkhung\\.vs-kubernetes\\tools\\draft\\windows-amd64\\draft.exe",
        "vs-kubernetes.kubectl-path.linux": "/home/huka/.vs-kubernetes/tools/kubectl/kubectl",
        "vs-kubernetes.minikube-path.linux": "/home/huka/.vs-kubernetes/tools/minikube/linux-amd64/minikube",
        "vs-kubernetes.helm-path.linux": "/home/huka/.vs-kubernetes/tools/helm/linux-amd64/helm",
        "vs-kubernetes.draft-path.linux": "/home/huka/.vs-kubernetes/tools/draft/linux-amd64/draft",
        "vscode-kubernetes.minikube-path.windows": "C:\\Users\\nlkhung\\.vs-kubernetes\\tools\\minikube\\windows-amd64\\minikube.exe"
    },
    "openapi.defaultPreviewRenderer": "redoc",
    "remote.SSH.remotePlatform": {
        "node1.online.int-vn.td.infra.sys": "linux",
        "node1.service.int-vn.td.infra.sys": "linux"
    },
    "editor.find.autoFindInSelection": "multiline",
    "blockhighlight.background": [
        "200",
        "100",
        "255",
        ".05"
    ],
    "highlight-matching-tag.styles": {
        "opening": {
            "name": {
                "underline": "red"
            }
        }
    },
    "local-history.path": "~",
    "local-history.daysLimit": 60,
    "workbench.editor.wrapTabs": true,
    "workbench.editor.tabSizing": "shrink",
    "editor.cursorBlinking": "expand",
    "editor.inlineHints.fontFamily": "'Cascadia Code', 'CaskaydiaCove Nerd Font', 'CaskaydiaCove NF'",
    "editor.renderWhitespace": "boundary",
    "css.validate": false,
    "editor.quickSuggestions": {
        "strings": true
    },
    "tailwindCSS.includeLanguages": {
        "plaintext": "html"
    },
    "tailwindCSS.emmetCompletions": true,
    "telemetry.enableTelemetry": false,
    "editor.codeLensFontFamily": "'Cascadia Code', 'CaskaydiaCove Nerd Font', 'CaskaydiaCove NF'",
    "markdown.preview.fontFamily": "'Cascadia Code', 'CaskaydiaCove Nerd Font', 'CaskaydiaCove NF'",
    "rest-client.fontFamily": "'Cascadia Code', 'CaskaydiaCove Nerd Font', 'CaskaydiaCove NF'",
    "rest-client.fontSize": 13,
    "go.autocompleteUnimportedPackages": true,
    "files.associations": {
        "sxhkdrc": "properties",
        "config": "properties",
        ".xprofile": "properties"
    },
    "diffEditor.ignoreTrimWhitespace": false,
    // "diffEditor.renderSideBySide": false,
    "window.newWindowDimensions": "offset",
    "editor.emptySelectionClipboard": false,
    // I removed the hyphen "-" from this list for better multi-cursor navigation.
    "editor.wordSeparators": "`~!@#$%^&*()=+[{]}\\|;:'\",.<>/?",
    "editor.quickSuggestionsDelay": 0,
    "editor.formatOnPaste": true,
    "editor.snippetSuggestions": "top",
    "editor.gotoLocation.multipleReferences": "goto",
    "editor.gotoLocation.multipleDefinitions": "goto",
    "editor.gotoLocation.multipleDeclarations": "goto",
    "editor.gotoLocation.multipleImplementations": "goto",
    "editor.gotoLocation.multipleTypeDefinitions": "goto",
    "editor.acceptSuggestionOnEnter": "off",
    "pasteImage.path": "${projectRoot}/inbox",
    "pasteImage.showFilePathConfirmInputBox": true,
    "foam.logging.level": "off",
    "foam.edit.linkReferenceDefinitions": "off",
    "foam.openDailyNote.directory": "note",
    "foam.openDailyNote.titleFormat": " ",
    "foam.openDailyNote.filenameFormat": "yyyymmddHHMMss",
    "vscodeMarkdownNotes.newNoteDirectory": "note",
    // "workbench.editor.highlightModifiedTabs": true,
    "vsicons.dontShowNewVersionMessage": true,
    "todo-tree.regex.regex": "(//|#|<!--|;|/\\*|^|^\\s*(-|\\d+.))\\s*($TAGS)",
    "todo-tree.general.tags": [
        "BUG",
        "HACK",
        "FIXME",
        "TODO",
        "XXX",
        "[ ]",
        "[x]"
    ],
    "workbench.editor.revealIfOpen": true,
    "search.followSymlinks": false,
    "breadcrumbs.enabled": false,
    "go.toolsManagement.autoUpdate": true,
    "explorer.autoReveal": false,
    "bracket-pair-colorizer-2.forceIterationColorCycle": true,
    "workbench.colorTheme": "Night Owl Light"
}